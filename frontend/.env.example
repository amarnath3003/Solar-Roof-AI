VITE_ROBOFLOW_API_URL=https://serverless.roboflow.com
VITE_ROBOFLOW_WORKSPACE=rooflayout
VITE_ROBOFLOW_WORKFLOW_ID=detect-count-and-visualize
# Optional direct workflow endpoint, e.g. https://detect.roboflow.com/workflow/detect-count-and-visualize
# If set, this takes precedence over API_URL/WORKSPACE/WORKFLOW_ID.
# VITE_ROBOFLOW_WORKFLOW_URL=
VITE_ROBOFLOW_API_KEY=your_roboflow_api_key_here
