{
  "name": "solar-roof-ai-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "preview": "npm run preview --workspace frontend",
    "frontend:dev": "npm run dev --workspace frontend",
    "backend:install": "python -m pip install -r backend/requirements.txt",
    "backend:dev": "python -m uvicorn app.main:app --reload --app-dir backend"
  }
}
